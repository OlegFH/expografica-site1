{
  "buildCommand": "echo 'Static site'",
  "outputDirectory": ".",
  "env": {
    "VERCEL_ENV": "production"
  },
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "send.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
